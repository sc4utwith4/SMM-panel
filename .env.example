# Chave da API BlackSMMRaja (Settings > API no painel deles)
SMM_API_KEY=sua_chave_aqui

# MercadoPago (mercadopago.com.br > Suas integrações > Credenciais)
MP_ACCESS_TOKEN=seu_token_aqui

# Supabase (supabase.com > Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# Segredo para assinar os JWTs (qualquer string longa e aleatória)
JWT_SECRET=troque_por_uma_string_aleatoria_longa

# URL do seu site no ar (usado pelo webhook do MercadoPago)
SITE_URL=https://seu-painel.vercel.app
